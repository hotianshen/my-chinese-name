# Copy to .env and fill in to go live. With these unset, the app runs in demo
# mode (orders are recorded locally and shown in /admin).

# Hosted checkout links — Lemon Squeezy (recommended: Merchant of Record, auto
# VAT/tax) or Stripe Payment Links.
VITE_CHECKOUT_DOSSIER=
VITE_CHECKOUT_MASTERS=
VITE_CHECKOUT_BRAND=

# Passcode for the /admin back-office (default: chengtian)
VITE_ADMIN_CODE=

# Base path. Leave unset ('/') for custom domains; the GitHub Pages workflow
# sets this to /<repo>/ automatically.
# VITE_BASE=/
